<script>
// ── State ──────────────────────────────────────────────────────
let currentScreen = 'draft';
let isDark = false;
let selectedObjCount = 3;
let selectedKRTypes = ['Transformational','Exploratory','Guardrail','Output'];
let selectedIndicators = ['X→Y Increase','X→Y Decrease','Keep ≥ threshold','Keep ≤ threshold'];
let contextFiles = [];
let pastedContext = '';
let currentOKRData = null;
let currentAnswerText = '';
let askState = 'idle'; // idle | streaming | done

const BREADCRUMBS = { draft: 'Draft OKR', ask: 'Ask Hail Mary', context: 'Context Library' };

// ── Navigation ─────────────────────────────────────────────────
function navigate(screen) {
  currentScreen = screen;
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => {
    n.classList.toggle('active', n.dataset.screen === screen);
  });
  const el = document.getElementById('screen-' + screen);
  if (el) el.classList.add('active');
  document.getElementById('breadcrumb-current').textContent = BREADCRUMBS[screen] || screen;
}

// ── Theme ──────────────────────────────────────────────────────
function toggleTheme() {
  isDark = !isDark;
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
  document.getElementById('theme-icon-sun').style.display  = isDark ? 'block' : 'none';
  document.getElementById('theme-icon-moon').style.display = isDark ? 'none' : 'block';
}

// ── Tag toggles ────────────────────────────────────────────────
document.querySelectorAll('#obj-count-tags .tag').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('#obj-count-tags .tag').forEach(x => x.classList.remove('on'));
    t.classList.add('on');
    selectedObjCount = parseInt(t.dataset.val);
  });
});
document.querySelectorAll('#kr-type-tags .tag').forEach(t => {
  t.addEventListener('click', () => {
    t.classList.toggle('on');
    selectedKRTypes = [...document.querySelectorAll('#kr-type-tags .tag.on')].map(x => x.dataset.val);
  });
});
document.querySelectorAll('#indicator-tags .tag').forEach(t => {
  t.addEventListener('click', () => {
    t.classList.toggle('on');
    selectedIndicators = [...document.querySelectorAll('#indicator-tags .tag.on')].map(x => x.dataset.val);
  });
});

// ── Context helpers ────────────────────────────────────────────
function buildContextBlock() {
  const parts = [];
  if (contextFiles.length) {
    parts.push('=== INTERNAL DOCUMENTS ===');
    contextFiles.forEach(f => parts.push(`\n[FILE: ${f.name}]\n${f.text.slice(0, 8000)}`));
  }
  if (pastedContext) parts.push('\n=== OKR KNOWLEDGE BASE ===\n' + pastedContext.slice(0, 6000));
  return parts.join('\n');
}

function updateContextUI() {
  const all = contextFiles.map(f=>f.text).join('\n') + pastedContext;
  const kb = Math.round(all.length / 1024);
  const tokens = Math.round(all.length / 4);
  const hasCtx = contextFiles.length > 0 || pastedContext.length > 0;

  document.getElementById('stat-files').textContent = contextFiles.length;
  document.getElementById('stat-kb').textContent = kb;
  document.getElementById('stat-tokens').textContent = tokens > 1000 ? Math.round(tokens/1000)+'K' : tokens;
  document.getElementById('ctx-file-preview').textContent = contextFiles.length
    ? contextFiles.map(f => '📄 ' + f.name).join('\n') + (pastedContext ? '\n📝 Pasted text' : '')
    : 'No files loaded yet.';

  // Update indicators
  ['ctx-badge','ctx-indicator'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.display = hasCtx ? 'inline-flex' : 'none';
  });
  const dot = document.getElementById('config-ctx-dot');
  const txt = document.getElementById('config-ctx-text');
  if (dot) dot.className = 'ctx-dot' + (hasCtx ? ' loaded' : '');
  if (txt) txt.textContent = hasCtx
    ? `${contextFiles.length} file${contextFiles.length!==1?'s':''} + ${pastedContext?'pasted text':''}`.replace(' + ', pastedContext ? ' + ' : '')
    : 'No context loaded';

  const ctxAsk = document.getElementById('ctx-status-ask');
  if (ctxAsk) ctxAsk.textContent = hasCtx ? `${contextFiles.length} files loaded` : 'No context';
}

async function handleFiles(files) {
  for (const file of files) {
    const chip = document.createElement('div');
    chip.className = 'file-chip';
    chip.innerHTML = `<span style="font-size:16px;">📄</span>
      <div style="flex:1;min-width:0;">
        <div class="file-name">${file.name}</div>
        <div class="file-meta">${file.name.split('.').pop().toUpperCase()} · ${Math.round(file.size/1024)}KB</div>
      </div>
      <span class="file-status reading">reading</span>
      <button onclick="this.closest('.file-chip').remove();contextFiles=contextFiles.filter(f=>f.name!=='${file.name}');updateContextUI();"
        style="color:var(--ink-3);font-size:16px;padding:0 2px;background:none;border:none;cursor:pointer;">×</button>`;
    document.getElementById('file-list').appendChild(chip);

    const text = await new Promise(resolve => {
      const reader = new FileReader();
      reader.onload = e => resolve(e.target.result);
      reader.onerror = () => resolve(`[Could not read: ${file.name}]`);
      if (file.name.endsWith('.pdf')) resolve(`[PDF: ${file.name} — paste text content in the box below for best results]`);
      else reader.readAsText(file);
    });
    contextFiles.push({ name: file.name, size: file.size, text });
    chip.querySelector('.file-status').textContent = 'ready';
    chip.querySelector('.file-status').className = 'file-status ready';
    updateContextUI();
  }
}

function saveContext() {
  pastedContext = document.getElementById('paste-context').value;
  updateContextUI();
  const btn = event.target;
  const orig = btn.innerHTML;
  btn.innerHTML = '✓ Saved';
  setTimeout(() => btn.innerHTML = orig, 2000);
}

function clearContext() {
  contextFiles = [];
  pastedContext = '';
  document.getElementById('file-list').innerHTML = '';
  document.getElementById('paste-context').value = '';
  updateContextUI();
}

// Drop zone
const dz = document.getElementById('drop-zone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('dragover'); });
dz.addEventListener('dragleave', () => dz.classList.remove('dragover'));
dz.addEventListener('drop', e => {
  e.preventDefault(); dz.classList.remove('dragover');
  handleFiles(e.dataTransfer.files);
});

// ── Generate OKR ───────────────────────────────────────────────
async function generateOKR() {
  const dept    = document.getElementById('cfg-dept').value.trim();
  const quarter = document.getElementById('cfg-quarter').value;
  const year    = document.getElementById('cfg-year').value;
  const focus   = document.getElementById('cfg-focus').value.trim();
  const extra   = document.getElementById('cfg-extra').value.trim();
  if (!focus) { alert('Please describe the strategic focus area.'); return; }

  setGenLoading(true);
  showStreaming();

  const ctx = buildContextBlock();
  const systemPrompt = ctx
    ? `You are an expert OKR coach for Net Capital, a Mongolian digital transformation company using SAFe 6.0. Use ONLY the following internal documents as your primary reference:\n\n${ctx}\n\nAlign all generated OKRs with the patterns, formats, and terminology in these documents.`
    : `You are an expert OKR coach specializing in SAFe 6.0 and corporate strategy for Mongolian digital transformation companies.`;

  const userPrompt = `Generate a complete OKR draft:
- Department: ${dept}
- Quarter: ${quarter} ${year}
- Objectives: ${selectedObjCount}
- Focus: ${focus}
- KR Types: ${selectedKRTypes.join(', ')}
- Indicator formats: ${selectedIndicators.join(', ')}
${extra ? `- Extra: ${extra}` : ''}

RULES:
1. 1 KR = 1 measurable indicator
2. Formats: X→Y (increase/decrease), Keep ≥ N, Keep ≤ N
3. KR types: Transformational | Exploratory | Guardrail | Output
4. Indicator type: Lagging | Leading
5. Objective weights sum to 100%
6. KR weights per Objective sum to 100%
7. 3-6 KRs per Objective

Respond ONLY with valid JSON, no markdown:
{"department":"string","quarter":"string","objectives":[{"id":"O1","title":"string","weight":40,"keyResults":[{"id":"KR1","title":"string","weight":20,"krType":"Transformational","indicatorType":"Lagging","format":"Increase","baseline":"0","target":"100","unit":"%","indicator":"Coverage 0% → 100%"}]}]}`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{ role: 'user', content: userPrompt }]
      })
    });
    const data = await response.json();
    if (!response.ok || data.error) throw new Error(data.error?.message || 'API error');
    const raw = data.content?.[0]?.text || '';
    streamGenerateOutput(raw, () => {
      try {
        const clean = raw.replace(/```json|```/g,'').trim();
        currentOKRData = JSON.parse(clean);
        renderOKR(currentOKRData, dept, quarter, year);
      } catch(e) {
        document.getElementById('streaming-text').textContent = raw;
      }
      setGenLoading(false);
    });
  } catch(err) {
    setGenLoading(false);
    showEmptyState();
    document.getElementById('output-empty').innerHTML = `<div class="empty-icon">⚠</div><div class="empty-text" style="color:var(--risk);">${err.message}</div>`;
  }
}

function setGenLoading(on) {
  const btn = document.getElementById('generate-btn');
  btn.disabled = on;
  document.getElementById('gen-label').style.display = on ? 'none' : 'inline';
  document.getElementById('gen-spinner').style.display = on ? 'block' : 'none';
}

function showStreaming() {
  document.getElementById('output-empty').style.display = 'none';
  document.getElementById('okr-rendered').style.display = 'none';
  document.getElementById('streaming-view').style.display = 'block';
  document.getElementById('output-toolbar').style.display = 'none';
  document.getElementById('streaming-text').textContent = '';
}

function showEmptyState() {
  document.getElementById('output-empty').style.display = 'flex';
  document.getElementById('okr-rendered').style.display = 'none';
  document.getElementById('streaming-view').style.display = 'none';
  document.getElementById('output-toolbar').style.display = 'none';
}

function streamGenerateOutput(text, onDone) {
  const el = document.getElementById('streaming-text');
  let i = 0;
  const cursor = '<span class="cursor"></span>';
  const step = () => {
    if (i < text.length) {
      el.innerHTML = esc(text.slice(0, i+1)) + cursor;
      i += Math.floor(Math.random()*5)+3;
      setTimeout(step, 10);
    } else { el.textContent = text; onDone(); }
  };
  step();
}

function renderOKR(data, dept, quarter, year) {
  document.getElementById('streaming-view').style.display = 'none';
  document.getElementById('okr-rendered').style.display = 'block';
  document.getElementById('output-toolbar').style.display = 'flex';
  document.getElementById('output-meta').textContent = `Generated · ${dept} ${quarter} ${year} · ${data.objectives?.length || 0} objectives`;

  const totalKRs = (data.objectives||[]).reduce((s,o) => s+(o.keyResults?.length||0), 0);
  const krTypes = {};
  (data.objectives||[]).forEach(o => (o.keyResults||[]).forEach(kr => {
    krTypes[kr.krType] = (krTypes[kr.krType]||0)+1;
  }));

  const container = document.getElementById('okr-rendered');
  container.innerHTML = `
    <div class="okr-meta-bar">
      <div class="meta-stat"><div class="meta-val">${(data.objectives||[]).length}</div><div class="meta-lbl">Objectives</div></div>
      <div class="meta-stat"><div class="meta-val">${totalKRs}</div><div class="meta-lbl">Key Results</div></div>
      <div class="meta-stat"><div class="meta-val">${krTypes['Transformational']||0}</div><div class="meta-lbl">Transform.</div></div>
      <div class="meta-stat"><div class="meta-val">${krTypes['Guardrail']||0}</div><div class="meta-lbl">Guardrail</div></div>
    </div>
    ${(data.objectives||[]).map((obj, oi) => `
      <div class="objective-card" style="animation-delay:${oi*0.08}s">
        <div class="obj-header">
          <span class="obj-id">${esc(obj.id)}</span>
          <div class="obj-title">${esc(obj.title)}</div>
          <span class="obj-weight">${obj.weight}%</span>
        </div>
        <div>
          ${(obj.keyResults||[]).map(kr => `
            <div class="kr-row">
              <div>
                <div class="kr-text">${esc(kr.title)}</div>
                <div class="kr-indicator">${esc(kr.indicator || `${kr.baseline} → ${kr.target} ${kr.unit||''}`)}</div>
              </div>
              <div class="kr-badges">
                <span class="badge badge-${(kr.krType||'').toLowerCase()}">${esc(kr.krType)}</span>
                <span class="badge badge-${(kr.indicatorType||'').toLowerCase()}">${esc(kr.indicatorType)}</span>
                <span class="badge badge-weight">${kr.weight}%</span>
              </div>
            </div>
          `).join('')}
        </div>
      </div>
    `).join('')}
  `;
}

function copyJSON() {
  if (!currentOKRData) return;
  navigator.clipboard.writeText(JSON.stringify(currentOKRData, null, 2));
  const btn = event.target.closest('button');
  const orig = btn.innerHTML;
  btn.textContent = '✓ Copied';
  setTimeout(() => btn.innerHTML = orig, 2000);
}

function exportCSV() {
  if (!currentOKRData) return;
  const rows = [['Objective','O_Weight','KR_ID','KR Title','KR Weight','KR Type','Indicator Type','Format','Baseline','Target','Unit','Indicator']];
  currentOKRData.objectives.forEach(o => o.keyResults.forEach(kr => {
    rows.push([o.title, o.weight+'%', kr.id, kr.title, kr.weight+'%', kr.krType, kr.indicatorType, kr.format||'', kr.baseline||'', kr.target||'', kr.unit||'', kr.indicator||'']);
  }));
  const csv = rows.map(r => r.map(c => `"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download = `HailMary_OKR_${currentOKRData.quarter}_${currentOKRData.department||'CSPD'}.csv`;
  a.click();
}

// ── Ask Hail Mary ──────────────────────────────────────────────
const SUGGESTED = [
  'What is the correct format for a Guardrail KR?',
  'How should I distribute weights across 3 objectives?',
  'Convert this goal into measurable KRs: "Improve team OKR quality this quarter"',
  'Review this KR and flag any issues: "Increase engagement"',
  'What is the difference between Lagging and Leading indicators?',
];

const TRACE_STEPS = [
  { step: 'Retrieve', detail: 'Semantic + keyword search across context library', ms: 142, items: 18 },
  { step: 'Filter', detail: 'Scope: CSPD · Q2 2026 · approved documents', ms: 18, items: 11 },
  { step: 'Rerank', detail: 'Cross-encoder scoring · top-5 retained', ms: 280, items: 5 },
  { step: 'Ground', detail: 'Claim extraction + source binding', ms: 390, items: 8 },
  { step: 'Synthesize', detail: 'Answer composition with references', ms: 820, items: 3 },
];

// Build suggested prompts
const spContainer = document.getElementById('suggested-prompts');
SUGGESTED.forEach(q => {
  const div = document.createElement('div');
  div.className = 'suggested-prompt';
  div.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3 M12 18v3 M4 12H1 M23 12h-3 M5.6 5.6l2.1 2.1 M16.3 16.3l2.1 2.1 M5.6 18.4l2.1-2.1 M16.3 7.7l2.1-2.1"/></svg><span>${q}</span>`;
  div.onclick = () => { document.getElementById('ask-input').value = q; runAsk(); };
  spContainer.appendChild(div);
});

function composerKeydown(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); runAsk(); }
}
function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 160) + 'px';
}

function resetAsk() {
  askState = 'idle';
  currentAnswerText = '';
  document.getElementById('ask-idle').style.display = 'block';
  document.getElementById('ask-answer').style.display = 'none';
  document.getElementById('ask-input').value = '';
  document.getElementById('evidence-list').innerHTML = '<div style="padding:24px 16px;text-align:center;color:var(--ink-3);font-size:12px;font-family:var(--font-mono);">Sources appear here after you ask a question</div>';
  document.getElementById('evidence-detail').style.display = 'none';
  document.getElementById('ev-count').textContent = '—';
}

async function runAsk() {
  const q = document.getElementById('ask-input').value.trim();
  if (!q || askState === 'streaming') return;

  askState = 'streaming';
  document.getElementById('ask-idle').style.display = 'none';
  document.getElementById('ask-answer').style.display = 'block';
  document.getElementById('ask-q-text').textContent = q;
  document.getElementById('ask-input').value = '';
  document.getElementById('ask-input').style.height = 'auto';
  document.getElementById('followups').style.display = 'none';
  document.getElementById('ask-actions').style.display = 'none';
  document.getElementById('answer-body').innerHTML = '<span class="cursor"></span>';
  document.getElementById('evidence-detail').style.display = 'none';

  // Animate trace
  const traceSteps = document.getElementById('trace-steps');
  traceSteps.innerHTML = TRACE_STEPS.map(() =>
    `<div class="trace-step"><div class="trace-fill"></div></div>`
  ).join('');
  const fills = traceSteps.querySelectorAll('.trace-step');
  let traceIdx = 0;
  const traceInterval = setInterval(() => {
    if (traceIdx < fills.length) { fills[traceIdx].classList.add('done'); traceIdx++; }
    else clearInterval(traceInterval);
  }, 220);

  // Build trace detail
  document.getElementById('trace-detail').innerHTML = TRACE_STEPS.map(t =>
    `<div class="trace-row"><span class="step-name">${t.step}</span><span style="flex:1;color:var(--ink-2);">${t.detail}</span><span class="step-ms">${t.ms}ms</span></div>`
  ).join('');
  document.getElementById('trace-summary').textContent = `${TRACE_STEPS.reduce((s,t)=>s+t.ms,0)}ms`;

  const ctx = buildContextBlock();
  const sysPrompt = [
    'You are Hail Mary, an OKR intelligence assistant for Net Capital (a Mongolian digital transformation company using SAFe 6.0).',
    'You are an expert in OKR methodology: Transformational/Exploratory/Guardrail/Output KR types, Lagging/Leading indicators, 1 KR = 1 indicator rule, X→Y / Keep ≥ / Keep ≤ formats, weight distribution.',
    ctx ? `\n\nINTERNAL CONTEXT:\n${ctx}` : ''
  ].join('');

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: sysPrompt,
        messages: [{ role: 'user', content: q }]
      })
    });
    const data = await resp.json();
    if (!resp.ok || data.error) throw new Error(data.error?.message || 'API error');
    const text = data.content?.[0]?.text || '';
    currentAnswerText = text;
    streamAnswer(text, () => {
      askState = 'done';
      showFollowups();
      showEvidenceItems();
      document.getElementById('ask-actions').style.display = 'flex';
    });
  } catch(err) {
    askState = 'done';
    document.getElementById('answer-body').textContent = 'Error: ' + err.message;
  }
}

function streamAnswer(text, onDone) {
  const el = document.getElementById('answer-body');
  el.innerHTML = '';
  let i = 0;
  const step = () => {
    if (i < text.length) {
      el.innerHTML = esc(text.slice(0,i+1)).replace(/\n/g,'<br>') + '<span class="cursor"></span>';
      i += Math.floor(Math.random()*4)+2;
      setTimeout(step, 12);
    } else {
      el.innerHTML = renderAnswerText(text);
      onDone();
    }
  };
  step();
}

function renderAnswerText(text) {
  return esc(text)
    .replace(/\n/g, '<br>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/`(.*?)`/g, `<code style="font-family:var(--font-mono);font-size:12px;background:var(--bg-2);padding:1px 5px;border-radius:3px;">$1</code>`);
}

function showFollowups() {
  const followupQuestions = [
    'Can you show a concrete example?',
    'How does this apply to my CSPD Q2 OKR?',
    'What's the difference between Lagging and Leading here?',
    'Draft a KR using the correct format',
  ];
  const el = document.getElementById('followups');
  el.style.display = 'flex';
  el.innerHTML = '<div style="font-size:11px;color:var(--ink-2);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.6px;margin-bottom:4px;">Follow-up</div>' +
    followupQuestions.map(q =>
      `<button class="followup-btn" onclick="document.getElementById('ask-input').value='${q}';runAsk();">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent);flex-shrink:0;"><path d="M12 3v3 M12 18v3 M4 12H1 M23 12h-3"/></svg>
        <span style="flex:1;">${q}</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="color:var(--ink-3);flex-shrink:0;"><path d="M5 12h14 M13 5l7 7-7 7"/></svg>
      </button>`
    ).join('');
}

const MOCK_SOURCES = [
  { n:1, title:'CSPD Q1 2026 OKR Definition Sheet', source:'Context Library · CSPD', type:'sheet', freshness:'Q1 2026', relevance:0.94, snippet:'KR 1 LPM players/roles тодорхойлогдож key role coverage 100% болгох — Weight: 20%, Type: Transformational…' },
  { n:2, title:'KR Library Rules — Net Capital', source:'Context Library · Evergreen', type:'doc', freshness:'Evergreen', relevance:0.89, snippet:'1 KR = 1 indicator дүрмийг баримтална. KR-г дараах форматуудаар хэмжигдэхүйц бичнэ: X→Y, Keep ≥, Keep ≤…' },
  { n:3, title:'SAFe 6.0 OKR Integration Guide', source:'Context Library · SAFe', type:'doc', freshness:'2026', relevance:0.81, snippet:'Transformational KRs challenge the status quo and require new capabilities. Exploratory KRs reduce uncertainty…' },
];

function showEvidenceItems() {
  const list = document.getElementById('evidence-list');
  document.getElementById('ev-count').textContent = MOCK_SOURCES.length + ' sources';
  list.innerHTML = MOCK_SOURCES.map((s,i) =>
    `<div class="evidence-item${i===0?' selected':''}" onclick="selectEvidence(${i})">
      <div class="ev-n">Source ${s.n} · ${Math.round(s.relevance*100)}% match</div>
      <div class="ev-title">${s.title}</div>
      <div class="ev-meta"><span>${s.source}</span><span>·</span><span>${s.freshness}</span></div>
      <div class="ev-relevance">
        <div class="ev-bar"><div class="ev-bar-fill" style="width:${s.relevance*100}%"></div></div>
      </div>
    </div>`
  ).join('');
  selectEvidence(0);
}

function selectEvidence(i) {
  document.querySelectorAll('.evidence-item').forEach((el,idx) => el.classList.toggle('selected', idx===i));
  const s = MOCK_SOURCES[i];
  const det = document.getElementById('evidence-detail');
  det.style.display = 'block';
  det.innerHTML = `
    <div class="ev-detail-title">${s.title}</div>
    <div class="ev-detail-meta">${s.source} · ${s.freshness} · ${Math.round(s.relevance*100)}% relevance</div>
    <div class="ev-snippet">${s.snippet}</div>
  `;
}

let traceOpen = false;
function toggleTrace() {
  traceOpen = !traceOpen;
  document.getElementById('trace-detail').classList.toggle('open', traceOpen);
  document.getElementById('trace-chevron').style.transform = traceOpen ? 'rotate(180deg)' : '';
}

function copyAnswer() {
  navigator.clipboard.writeText(currentAnswerText);
  const btn = event.target.closest('button');
  const orig = btn.innerHTML;
  btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';
  setTimeout(() => btn.innerHTML = orig, 2000);
}

// ── Utility ────────────────────────────────────────────────────
function esc(str) {
  return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// Init
updateContextUI();
</script>

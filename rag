<!DOCTYPE html>
<html lang="en" data-theme="light" data-accent="navy">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hail Mary — OKR Drafting Intelligence</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ── CSS Variables ─────────────────────────────────────────── */
:root {
  --font-sans:   'IBM Plex Sans', sans-serif;
  --font-serif:  'IBM Plex Serif', Georgia, serif;
  --font-mono:   'IBM Plex Mono', monospace;
  --sidebar-w:   224px;
  --header-h:    48px;
  --radius:      4px;
  --radius-md:   6px;
  --radius-lg:   8px;
}

[data-theme="light"] {
  --bg-0:       #faf9f5;
  --bg-1:       #ffffff;
  --bg-2:       #f3f2ee;
  --bg-3:       #e8e6e0;
  --bg-ai:      #f0eef8;
  --ink-0:      #111110;
  --ink-1:      #2c2c2a;
  --ink-2:      #6b6b68;
  --ink-3:      #9e9e9a;
  --ink-4:      #c8c8c2;
  --line-0:     #e8e6e0;
  --line-1:     #d4d2cc;
  --line-ai:    #c8c0e8;
  --ok:         #1a7a4a;
  --ok-soft:    #ddf0e4;
  --warn:       #8a5a00;
  --warn-soft:  #fff0d0;
  --risk:       #b52828;
  --risk-soft:  #fde8e8;
  --info:       #1a4a8a;
  --info-soft:  #e0eaff;
  --conf-hi:    #1a7a4a;
  --conf-mid:   #8a5a00;
  --conf-lo:    #b52828;
  --accent:        #0F1F4C;
  --accent-hover:  #15286B;
  --accent-soft:   #E6EAF5;
  --accent-ink:    #0F1F4C;
  --accent-on:     #ffffff;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
  --shadow-lg: 0 8px 24px rgba(0,0,0,0.1), 0 4px 8px rgba(0,0,0,0.06);
}

[data-theme="dark"] {
  --bg-0:       #111110;
  --bg-1:       #1a1a18;
  --bg-2:       #222220;
  --bg-3:       #2e2e2c;
  --bg-ai:      #1a1828;
  --ink-0:      #f0ede6;
  --ink-1:      #c8c5be;
  --ink-2:      #888580;
  --ink-3:      #585855;
  --ink-4:      #383835;
  --line-0:     #2c2c2a;
  --line-1:     #3a3a38;
  --line-ai:    #3a3058;
  --ok:         #4caf78;
  --ok-soft:    #0d2a1a;
  --warn:       #e0a030;
  --warn-soft:  #2a1e00;
  --risk:       #e86060;
  --risk-soft:  #2a0f0f;
  --info:       #6090e0;
  --info-soft:  #0a1a30;
  --conf-hi:    #4caf78;
  --conf-mid:   #e0a030;
  --conf-lo:    #e86060;
  --accent:        #8EA0FF;
  --accent-hover:  #A6B4FF;
  --accent-soft:   #1A1F3A;
  --accent-ink:    #C7D0FF;
  --accent-on:     #0a0f2a;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.3);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
  --shadow-lg: 0 8px 24px rgba(0,0,0,0.5);
}

/* ── Reset ──────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body {
  font-family: var(--font-sans);
  font-size: 14px;
  color: var(--ink-0);
  background: var(--bg-0);
  -webkit-font-smoothing: antialiased;
}
button { font-family: inherit; cursor: pointer; border: none; background: none; }
input, textarea, select { font-family: inherit; }
a { color: inherit; text-decoration: none; }

/* ── Keyframes ──────────────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes blink {
  0%, 49% { opacity: 1; }
  50%, 100% { opacity: 0; }
}
@keyframes popIn {
  0%   { transform: scale(0.5); opacity: 0; }
  60%  { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(1); }
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
@keyframes traceSlide {
  from { transform: translateX(-100%); }
  to   { transform: translateX(0); }
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.fade-up { animation: fadeUp .2s ease both; }

/* ── Layout shell ───────────────────────────────────────────── */
#app { display: flex; height: 100vh; overflow: hidden; }

/* ── Sidebar ────────────────────────────────────────────────── */
#sidebar {
  width: var(--sidebar-w);
  flex-shrink: 0;
  background: var(--bg-2);
  border-right: 1px solid var(--line-0);
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
  z-index: 10;
}

.sidebar-brand {
  height: var(--header-h);
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 14px;
  border-bottom: 1px solid var(--line-0);
  flex-shrink: 0;
}
.brand-mark {
  width: 24px; height: 24px;
  border-radius: 5px;
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-mono);
  font-weight: 700; font-size: 12px;
  color: var(--accent-on);
  letter-spacing: -0.5px;
  flex-shrink: 0;
}
.brand-text { display: flex; flex-direction: column; line-height: 1.15; }
.brand-name { font-weight: 600; font-size: 14px; letter-spacing: -0.2px; color: var(--ink-0); }
.brand-sub  { font-size: 10.5px; color: var(--ink-2); }

.sidebar-nav { padding: 10px 8px; flex: 1; overflow-y: auto; }
.nav-section-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--ink-3);
  padding: 10px 8px 4px;
  font-family: var(--font-mono);
}
.nav-item {
  display: flex; align-items: center; gap: 9px;
  padding: 7px 8px;
  border-radius: var(--radius-md);
  font-size: 13px; font-weight: 400;
  color: var(--ink-1);
  cursor: pointer;
  transition: background .12s, color .12s;
  position: relative;
  user-select: none;
}
.nav-item:hover  { background: var(--bg-3); }
.nav-item.active { background: var(--bg-1); color: var(--ink-0); font-weight: 500; box-shadow: var(--shadow-sm); }
.nav-item .ai-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--accent);
  position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
}

.sidebar-bottom {
  padding: 10px 8px 12px;
  border-top: 1px solid var(--line-0);
}
.user-row {
  display: flex; align-items: center; gap: 8px;
  padding: 7px 8px; border-radius: var(--radius-md);
  cursor: pointer; transition: background .12s;
}
.user-row:hover { background: var(--bg-3); }
.avatar {
  width: 26px; height: 26px; border-radius: 50%;
  background: var(--accent);
  color: var(--accent-on);
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 600;
  font-family: var(--font-mono);
  flex-shrink: 0;
}
.user-info { flex: 1; min-width: 0; }
.user-name { font-size: 12.5px; font-weight: 500; color: var(--ink-0); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.user-role { font-size: 11px; color: var(--ink-2); }

/* ── Main area ──────────────────────────────────────────────── */
#main { flex: 1; display: flex; flex-direction: column; min-width: 0; background: var(--bg-0); }

/* ── Topbar ─────────────────────────────────────────────────── */
#topbar {
  height: var(--header-h);
  border-bottom: 1px solid var(--line-0);
  display: flex; align-items: center;
  padding: 0 20px 0 16px;
  gap: 10px;
  background: var(--bg-1);
  flex-shrink: 0;
}
.breadcrumb {
  display: flex; align-items: center; gap: 5px;
  font-size: 12px; color: var(--ink-2);
  font-family: var(--font-mono);
}
.breadcrumb .sep { color: var(--ink-4); }
.breadcrumb .current { color: var(--ink-0); font-weight: 500; }
.topbar-actions { margin-left: auto; display: flex; align-items: center; gap: 6px; }

/* ── Buttons ────────────────────────────────────────────────── */
.btn {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 5px 11px;
  border-radius: var(--radius);
  font-size: 13px; font-weight: 500;
  transition: background .12s, border-color .12s, color .12s, box-shadow .12s;
  cursor: pointer; white-space: nowrap; border: 1px solid transparent;
  font-family: var(--font-sans);
}
.btn-primary  { background: var(--accent); color: var(--accent-on); }
.btn-primary:hover { background: var(--accent-hover); }
.btn-secondary { background: var(--bg-1); color: var(--ink-1); border-color: var(--line-1); }
.btn-secondary:hover { background: var(--bg-2); border-color: var(--line-0); }
.btn-ghost { color: var(--ink-1); }
.btn-ghost:hover { background: var(--bg-2); }
.btn-sm { padding: 3px 9px; font-size: 12px; }
.btn-danger { background: var(--risk-soft); color: var(--risk); border-color: transparent; }
.btn-danger:hover { background: var(--risk); color: white; }
.icon-btn {
  width: 28px; height: 28px;
  display: inline-flex; align-items: center; justify-content: center;
  border-radius: var(--radius);
  color: var(--ink-2); cursor: pointer;
  transition: background .12s, color .12s;
  border: none; background: none;
}
.icon-btn:hover { background: var(--bg-2); color: var(--ink-0); }

/* ── Cards ──────────────────────────────────────────────────── */
.card {
  background: var(--bg-1);
  border: 1px solid var(--line-0);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.card-ai {
  background: var(--bg-ai);
  border-color: var(--line-ai);
}
.card-header {
  padding: 12px 16px;
  border-bottom: 1px solid var(--line-0);
  display: flex; align-items: center; gap: 8px;
}
.card-title { font-size: 13px; font-weight: 500; color: var(--ink-0); }

/* ── AI Badge ───────────────────────────────────────────────── */
.ai-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 2px 6px; border-radius: 3px;
  font-family: var(--font-mono);
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.5px; text-transform: uppercase;
  color: var(--accent-ink);
  background: var(--accent-soft);
  border: 1px solid var(--line-ai);
}
.ai-badge .dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent); }

/* ── Status pills ───────────────────────────────────────────── */
.pill {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 2px 7px; border-radius: 3px;
  font-size: 11.5px; font-weight: 500;
  white-space: nowrap;
}
.pill-ok   { background: var(--ok-soft);   color: var(--ok);   }
.pill-warn { background: var(--warn-soft);  color: var(--warn); }
.pill-risk { background: var(--risk-soft);  color: var(--risk); }
.pill-info { background: var(--info-soft);  color: var(--info); }
.pill-neutral { background: var(--bg-3); color: var(--ink-1); }

/* ── Chips ──────────────────────────────────────────────────── */
.chip {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 8px; border-radius: 3px;
  font-size: 11.5px; font-weight: 500;
  cursor: pointer; user-select: none;
  border: 1px solid transparent;
  transition: background .1s, color .1s, border-color .1s;
  background: var(--bg-2); color: var(--ink-1);
}
.chip:hover { background: var(--bg-3); }
.chip.active { background: var(--accent-soft); color: var(--accent-ink); border-color: var(--accent); }

/* ── Screens ────────────────────────────────────────────────── */
.screen { flex: 1; display: none; flex-direction: column; min-height: 0; overflow: hidden; }
.screen.active { display: flex; animation: fadeUp .18s ease; }

/* ── Screen: Draft ──────────────────────────────────────────── */
#screen-draft { flex-direction: row; }

.draft-config {
  width: 320px;
  flex-shrink: 0;
  border-right: 1px solid var(--line-0);
  display: flex; flex-direction: column;
  background: var(--bg-1);
  overflow-y: auto;
}
.config-section { padding: 16px; border-bottom: 1px solid var(--line-0); }
.config-label {
  font-size: 10.5px; font-weight: 600;
  letter-spacing: 0.8px; text-transform: uppercase;
  color: var(--ink-2); font-family: var(--font-mono);
  margin-bottom: 8px;
}
.form-field { margin-bottom: 10px; }
.form-label { font-size: 12px; color: var(--ink-2); margin-bottom: 4px; display: block; }
.form-input, .form-select, .form-textarea {
  width: 100%; padding: 7px 10px;
  border: 1px solid var(--line-0);
  border-radius: var(--radius);
  background: var(--bg-0); color: var(--ink-0);
  font-size: 13px; font-family: var(--font-sans);
  outline: none; transition: border-color .15s, box-shadow .15s;
}
.form-input:focus, .form-select:focus, .form-textarea:focus {
  border-color: var(--accent); box-shadow: 0 0 0 2px var(--accent-soft);
}
.form-textarea { resize: vertical; line-height: 1.55; min-height: 72px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

.tag-group { display: flex; flex-wrap: wrap; gap: 4px; }
.tag {
  padding: 3px 8px; border-radius: 20px; font-size: 11.5px;
  border: 1px solid var(--line-1); color: var(--ink-1);
  cursor: pointer; user-select: none; transition: all .12s;
  font-family: var(--font-mono);
}
.tag:hover { border-color: var(--accent); color: var(--accent); }
.tag.on { background: var(--accent-soft); border-color: var(--accent); color: var(--accent-ink); }

.context-status {
  display: flex; align-items: center; gap: 6px;
  padding: 7px 10px; border-radius: var(--radius);
  background: var(--bg-0); border: 1px solid var(--line-0);
  font-size: 12px; color: var(--ink-1);
  cursor: pointer; transition: border-color .12s;
}
.context-status:hover { border-color: var(--accent); }
.ctx-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--ink-3); flex-shrink: 0; }
.ctx-dot.loaded { background: var(--ok); }

.generate-btn {
  width: 100%; padding: 10px;
  background: var(--accent); color: var(--accent-on);
  border-radius: var(--radius); font-size: 13.5px; font-weight: 600;
  display: flex; align-items: center; justify-content: center; gap: 7px;
  transition: background .12s, opacity .12s;
  font-family: var(--font-sans);
}
.generate-btn:hover:not(:disabled) { background: var(--accent-hover); }
.generate-btn:disabled { opacity: 0.5; cursor: not-allowed; }

/* ── Draft output ───────────────────────────────────────────── */
.draft-output {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column;
  overflow: hidden;
}
.output-toolbar {
  padding: 10px 20px;
  border-bottom: 1px solid var(--line-0);
  display: flex; align-items: center; gap: 8px;
  background: var(--bg-1); flex-shrink: 0;
}
.output-body { flex: 1; overflow-y: auto; padding: 20px; }

.output-empty {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 12px; color: var(--ink-3);
  padding: 40px;
}
.empty-icon { font-size: 36px; opacity: 0.4; }
.empty-text { font-size: 13px; font-family: var(--font-mono); text-align: center; max-width: 220px; line-height: 1.6; }

.streaming-pre {
  font-family: var(--font-mono); font-size: 12px;
  color: var(--ink-1); white-space: pre-wrap;
  line-height: 1.7; padding: 16px;
  background: var(--bg-0); border: 1px solid var(--line-0);
  border-radius: var(--radius-lg);
}
.cursor { display: inline-block; width: 2px; height: 14px; background: var(--accent); vertical-align: middle; margin-left: 1px; animation: blink 1s step-end infinite; }

/* OKR output cards */
.okr-meta-bar {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: var(--line-0);
  border: 1px solid var(--line-0);
  border-radius: var(--radius-lg); overflow: hidden;
  margin-bottom: 16px;
}
.meta-stat {
  background: var(--bg-1); padding: 12px 14px; text-align: center;
}
.meta-val { font-family: var(--font-mono); font-size: 22px; font-weight: 600; color: var(--accent); }
.meta-lbl { font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.6px; margin-top: 3px; font-family: var(--font-mono); }

.objective-card {
  background: var(--bg-1); border: 1px solid var(--line-0);
  border-radius: var(--radius-lg); margin-bottom: 12px;
  overflow: hidden;
  animation: fadeUp .25s ease both;
}
.obj-header {
  padding: 12px 16px;
  border-bottom: 1px solid var(--line-0);
  display: flex; align-items: flex-start; gap: 10px;
  background: var(--bg-2);
}
.obj-id {
  font-family: var(--font-mono); font-size: 10px;
  color: var(--accent-ink); background: var(--accent-soft);
  border: 1px solid var(--line-ai);
  padding: 2px 7px; border-radius: 3px;
  white-space: nowrap; margin-top: 2px;
  letter-spacing: 0.5px;
}
.obj-title {
  font-family: var(--font-serif); font-size: 15px;
  font-weight: 500; line-height: 1.4; flex: 1;
  color: var(--ink-0);
}
.obj-weight { font-family: var(--font-mono); font-size: 12px; color: var(--warn); margin-top: 2px; white-space: nowrap; }

.kr-row {
  padding: 10px 16px 10px 36px;
  display: grid; grid-template-columns: 1fr auto;
  gap: 10px; align-items: start;
  border-bottom: 1px solid var(--line-0);
  position: relative; transition: background .1s;
}
.kr-row:last-child { border-bottom: none; }
.kr-row:hover { background: var(--bg-0); }
.kr-row::before {
  content: '';
  position: absolute; left: 18px; top: 18px;
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--bg-3);
}
.kr-text { font-size: 13px; line-height: 1.5; color: var(--ink-0); }
.kr-indicator {
  font-family: var(--font-mono); font-size: 11px;
  color: var(--ink-2); margin-top: 4px;
  padding: 2px 7px; background: var(--bg-0);
  border: 1px solid var(--line-0); border-radius: 3px;
  display: inline-block;
}
.kr-badges { display: flex; gap: 4px; flex-wrap: wrap; justify-content: flex-end; }
.badge {
  font-family: var(--font-mono); font-size: 9.5px;
  padding: 2px 6px; border-radius: 3px;
  text-transform: uppercase; white-space: nowrap; letter-spacing: 0.3px;
}
.badge-transformational { background: #E6EAF5; color: #0F1F4C; border: 1px solid #C8D0E8; }
.badge-exploratory  { background: #F0E8FA; color: #6020A0; border: 1px solid #D8B0F0; }
.badge-guardrail    { background: var(--warn-soft); color: var(--warn); border: 1px solid #E8D090; }
.badge-output       { background: var(--ok-soft); color: var(--ok); border: 1px solid #A8D8B8; }
.badge-lagging      { background: var(--risk-soft); color: var(--risk); border: 1px solid #F0B0B0; }
.badge-leading      { background: var(--ok-soft); color: var(--ok); border: 1px solid #A8D8B8; }
.badge-weight       { background: var(--bg-2); color: var(--ink-2); border: 1px solid var(--line-0); }

[data-theme="dark"] .badge-transformational { background: #1A1F3A; color: #8EA0FF; border-color: #3A4070; }
[data-theme="dark"] .badge-exploratory { background: #200A38; color: #C090F0; border-color: #501880; }

/* ── Screen: Ask ────────────────────────────────────────────── */
#screen-ask { flex-direction: row; }

.ask-main {
  flex: 1; min-width: 0; display: flex; flex-direction: column;
  overflow: hidden; position: relative;
}
.ask-scroll {
  flex: 1; overflow-y: auto;
  padding: 36px 0 120px;
}
.ask-inner { max-width: 720px; width: 100%; margin: 0 auto; padding: 0 32px; }

.ask-hero { text-align: center; padding: 48px 20px 32px; }
.ask-hero-title {
  font-family: var(--font-serif); font-size: 32px;
  font-weight: 500; color: var(--ink-0);
  letter-spacing: -0.4px; margin-bottom: 8px;
}
.ask-hero-sub { font-size: 14px; color: var(--ink-2); line-height: 1.6; }

.suggested-prompts { margin-top: 28px; display: flex; flex-direction: column; gap: 6px; }
.suggested-prompt {
  display: flex; align-items: center; gap: 10px;
  padding: 11px 14px;
  border: 1px solid var(--line-0); border-radius: var(--radius-md);
  background: var(--bg-1); color: var(--ink-0);
  font-size: 13px; cursor: pointer; text-align: left;
  transition: border-color .12s, background .12s;
}
.suggested-prompt:hover { background: var(--bg-2); border-color: var(--line-1); }
.suggested-prompt svg { color: var(--accent); flex-shrink: 0; }

.ask-composer-wrap {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 16px 32px 20px;
  background: linear-gradient(to top, var(--bg-0) 75%, transparent);
}
.ask-composer-inner { max-width: 720px; margin: 0 auto; }
.composer {
  display: flex; align-items: flex-end; gap: 8px;
  background: var(--bg-1); border: 1px solid var(--line-1);
  border-radius: var(--radius-lg); padding: 10px 12px;
  box-shadow: var(--shadow-md);
  transition: border-color .15s, box-shadow .15s;
}
.composer:focus-within { border-color: var(--accent); box-shadow: 0 0 0 2px var(--accent-soft), var(--shadow-md); }
.composer-input {
  flex: 1; border: none; outline: none; background: transparent;
  font-size: 14px; color: var(--ink-0); resize: none;
  line-height: 1.5; min-height: 24px; max-height: 160px;
  font-family: var(--font-sans);
}
.composer-input::placeholder { color: var(--ink-3); }
.composer-send {
  width: 34px; height: 34px; border-radius: var(--radius);
  background: var(--accent); color: var(--accent-on);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: background .12s, opacity .12s;
}
.composer-send:hover:not(:disabled) { background: var(--accent-hover); }
.composer-send:disabled { opacity: 0.4; cursor: not-allowed; }

/* Question block */
.q-block { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 20px; }
.q-avatar {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--ink-1); color: var(--bg-1);
  font-size: 10px; font-weight: 600; font-family: var(--font-mono);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.q-text {
  font-family: var(--font-serif); font-size: 22px;
  font-weight: 500; line-height: 1.35; letter-spacing: -0.2px;
  color: var(--ink-0); flex: 1;
}
.q-meta { font-size: 11.5px; color: var(--ink-2); margin-top: 6px; font-family: var(--font-mono); }

/* Trace bar */
.trace-bar {
  margin: 14px 0; padding: 8px 12px;
  border: 1px solid var(--line-0); border-radius: var(--radius-md);
  background: var(--bg-1); cursor: pointer;
  display: flex; align-items: center; gap: 8px;
  font-size: 12px; color: var(--ink-2);
  transition: border-color .12s;
}
.trace-bar:hover { border-color: var(--accent); }
.trace-steps { display: flex; gap: 0; flex: 1; overflow: hidden; }
.trace-step {
  flex: 1; height: 3px; background: var(--bg-3);
  position: relative; overflow: hidden;
}
.trace-step + .trace-step { margin-left: 2px; }
.trace-step.done .trace-fill {
  position: absolute; inset: 0;
  background: var(--accent);
  animation: traceSlide .3s ease both;
}
.trace-detail {
  margin-top: 8px; padding: 10px 12px;
  background: var(--bg-0); border: 1px solid var(--line-0);
  border-radius: var(--radius); font-size: 12px; font-family: var(--font-mono);
  display: none;
}
.trace-detail.open { display: block; animation: fadeUp .15s ease; }
.trace-row { display: flex; gap: 8px; align-items: center; padding: 3px 0; color: var(--ink-2); }
.trace-row .step-name { font-weight: 600; color: var(--accent); min-width: 72px; }
.trace-row .step-ms { color: var(--ink-3); min-width: 42px; text-align: right; }

/* Answer block */
.answer-block {
  background: var(--bg-ai);
  border: 1px solid var(--line-ai);
  border-radius: var(--radius-lg);
  padding: 18px 20px;
  margin-bottom: 16px;
}
.answer-header { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
.answer-body {
  font-size: 14px; line-height: 1.75; color: var(--ink-0);
  white-space: pre-wrap; font-family: var(--font-sans);
}
.answer-body .emph-bold { font-weight: 600; }
.answer-body .emph-num { font-family: var(--font-mono); color: var(--accent-ink); font-weight: 500; }
.answer-body .emph-conf-hi { color: var(--ok); font-weight: 600; font-family: var(--font-mono); }
.answer-body .emph-conf-mid { color: var(--warn); font-weight: 600; font-family: var(--font-mono); }
.cite-ref {
  display: inline-flex; align-items: center; justify-content: center;
  width: 15px; height: 15px; border-radius: 50%;
  background: var(--accent); color: var(--accent-on);
  font-size: 9px; font-weight: 700; font-family: var(--font-mono);
  cursor: pointer; vertical-align: super;
  margin: 0 1px; flex-shrink: 0;
  animation: popIn .2s ease both;
  transition: transform .1s;
}
.cite-ref:hover { transform: scale(1.2); }

/* Follow-up suggestions */
.followups { margin-top: 20px; display: flex; flex-direction: column; gap: 6px; }
.followup-btn {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 12px; border: 1px solid var(--line-0);
  border-radius: var(--radius); background: var(--bg-1);
  color: var(--ink-0); font-size: 13px; text-align: left;
  cursor: pointer; transition: background .12s, border-color .12s;
}
.followup-btn:hover { background: var(--bg-2); border-color: var(--line-1); }

/* Evidence pane */
.evidence-pane {
  width: 320px; flex-shrink: 0;
  border-left: 1px solid var(--line-0);
  display: flex; flex-direction: column;
  background: var(--bg-1); overflow: hidden;
}
.evidence-header {
  padding: 11px 14px; border-bottom: 1px solid var(--line-0);
  display: flex; align-items: center; gap: 6px; flex-shrink: 0;
}
.evidence-list { flex: 1; overflow-y: auto; }
.evidence-item {
  padding: 12px 14px; border-bottom: 1px solid var(--line-0);
  cursor: pointer; transition: background .1s;
}
.evidence-item:hover { background: var(--bg-0); }
.evidence-item.selected { background: var(--accent-soft); border-left: 3px solid var(--accent); padding-left: 11px; }
.ev-n { font-family: var(--font-mono); font-size: 9px; font-weight: 600; color: var(--accent); margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; }
.ev-title { font-size: 12.5px; font-weight: 500; color: var(--ink-0); line-height: 1.35; margin-bottom: 4px; }
.ev-meta { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--ink-2); font-family: var(--font-mono); flex-wrap: wrap; }
.ev-relevance { display: flex; align-items: center; gap: 4px; margin-top: 6px; }
.ev-bar { flex: 1; height: 3px; background: var(--bg-3); border-radius: 2px; overflow: hidden; }
.ev-bar-fill { height: 100%; background: var(--accent); border-radius: 2px; }

.evidence-detail {
  border-top: 1px solid var(--line-0);
  padding: 14px; flex-shrink: 0;
  max-height: 240px; overflow-y: auto;
}
.ev-detail-title { font-size: 13px; font-weight: 600; color: var(--ink-0); margin-bottom: 4px; line-height: 1.3; }
.ev-detail-meta { font-size: 11px; color: var(--ink-2); margin-bottom: 8px; font-family: var(--font-mono); line-height: 1.6; }
.ev-snippet {
  font-size: 12px; color: var(--ink-1); line-height: 1.65;
  font-style: italic; padding: 8px 10px;
  background: var(--bg-0); border-left: 2px solid var(--accent);
  border-radius: 0 3px 3px 0;
}

/* ── Screen: Context ────────────────────────────────────────── */
#screen-context {
  flex-direction: row;
}
.context-panel {
  flex: 1; overflow-y: auto; padding: 24px;
}
.context-sidebar {
  width: 300px; flex-shrink: 0;
  border-left: 1px solid var(--line-0);
  display: flex; flex-direction: column;
  background: var(--bg-1); padding: 16px; gap: 14px;
  overflow-y: auto;
}
.drop-zone {
  border: 2px dashed var(--line-1); border-radius: var(--radius-lg);
  padding: 32px 20px; text-align: center;
  cursor: pointer; transition: all .15s; background: var(--bg-0);
  position: relative;
}
.drop-zone:hover, .drop-zone.dragover { border-color: var(--accent); background: var(--accent-soft); }
.drop-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.drop-title { font-size: 14px; font-weight: 500; color: var(--ink-0); margin-bottom: 4px; }
.drop-sub { font-size: 12px; color: var(--ink-2); font-family: var(--font-mono); }
.file-chip {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 10px; background: var(--bg-1);
  border: 1px solid var(--line-0); border-radius: var(--radius-md);
  animation: fadeUp .15s ease;
}
.file-name { flex: 1; font-size: 12.5px; color: var(--ink-0); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.file-meta { font-size: 11px; color: var(--ink-2); font-family: var(--font-mono); }
.file-status {
  font-size: 10px; padding: 2px 6px; border-radius: 10px; font-family: var(--font-mono); white-space: nowrap;
}
.file-status.ready   { background: var(--ok-soft); color: var(--ok); }
.file-status.reading { background: var(--accent-soft); color: var(--accent-ink); }
.ctx-stat { text-align: center; padding: 12px; background: var(--bg-0); border: 1px solid var(--line-0); border-radius: var(--radius-md); }
.ctx-stat-val { font-family: var(--font-mono); font-size: 22px; font-weight: 600; color: var(--accent); }
.ctx-stat-lbl { font-size: 10.5px; color: var(--ink-2); text-transform: uppercase; letter-spacing: 0.6px; margin-top: 3px; font-family: var(--font-mono); }

/* ── Theme toggle ───────────────────────────────────────────── */
.theme-toggle {
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius); color: var(--ink-2);
  cursor: pointer; transition: background .12s, color .12s;
}
.theme-toggle:hover { background: var(--bg-2); color: var(--ink-0); }

/* ── Progress bar ───────────────────────────────────────────── */
.progress-track { height: 4px; background: var(--bg-3); border-radius: 2px; overflow: hidden; position: relative; }
.progress-fill { height: 100%; border-radius: 2px; transition: width .6s cubic-bezier(.2,.7,.3,1); }

/* ── Section label ──────────────────────────────────────────── */
.section-label {
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.8px; text-transform: uppercase;
  color: var(--ink-2); font-family: var(--font-mono);
  padding-bottom: 10px; margin-bottom: 12px;
  border-bottom: 1px solid var(--line-0);
}

/* ── Spinner ────────────────────────────────────────────────── */
.spinner {
  width: 16px; height: 16px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin .7s linear infinite;
}

/* ── Scrollbars ─────────────────────────────────────────────── */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--bg-3); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--line-1); }

/* ── SVG icons ──────────────────────────────────────────────── */
.icon { display: inline-block; flex-shrink: 0; }
</style>
</head>
